+.finding-row.in-brief .finding-check { border-color: rgba(255,255,255,0.92); background: rgba(255,255,255,0.08); }
+.finding-row.in-brief .finding-check::after { opacity: 1; background: rgba(255,255,255,0.95); }
+
+.finding-body {
